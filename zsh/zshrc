#
# User configuration sourced by interactive shells
#

# ensure (F)PATH entries remain unique
typeset -U path fpath

# Editor
# In absence of explicit zle configuration (e.g. via bindkey), Zsh sets its key bindings based on the value of $EDITOR.
# We set it first to be on the safe side.
export EDITOR=vi
export VISUAL=vi

# Fpath mangling for user functions
fpath=(${HOME}/.local/share/zsh/site-functions $fpath)
if (( ${+GHOSTTY_RESOURCES_DIR} )) && [[ -d ${GHOSTTY_RESOURCES_DIR} ]]; then
	fpath=(${GHOSTTY_RESOURCES_DIR:h}/zsh/site-functions $fpath)
fi


# -----------------
# Zsh configuration
# -----------------

#
# History
#

# Remove older command from the history if a duplicate is to be added.
setopt HIST_IGNORE_ALL_DUPS

#
# Input/output
#

# Set editor default keymap to emacs (`-e`) or vi (`-v`)
bindkey -v

# Prompt for spelling correction of commands.
#setopt CORRECT

# Customize spelling correction prompt.
#SPROMPT='zsh: correct %F{red}%R%f to %F{green}%r%f [nyae]? '

# Remove path separator from WORDCHARS.
WORDCHARS=${WORDCHARS//[\/]}

# -----------------
# Zim configuration
# -----------------

# Use degit instead of git as the default tool to install and update modules.
#zstyle ':zim:zmodule' use 'degit'

# --------------------
# Module configuration
# --------------------

#
# git
#

# Set a custom prefix for the generated aliases. The default prefix is 'G'.
#zstyle ':zim:git' aliases-prefix 'g'

#
# input
#

# Append `../` to your input for each `.` you type after an initial `..`
#zstyle ':zim:input' double-dot-expand yes

#
# termtitle
#

# Set a custom terminal title format using prompt expansion escape sequences.
# See http://zsh.sourceforge.net/Doc/Release/Prompt-Expansion.html#Simple-Prompt-Escapes
# If none is provided, the default '%n@%m: %~' is used.
#zstyle ':zim:termtitle' format '%1~'
zstyle ':zim:termtitle' hooks 'preexec' 'precmd'
zstyle ':zim:termtitle:preexec' format '${(V)2}'

#
# zsh-autosuggestions
#

# Disable automatic widget re-binding on each precmd. This can be set when
# zsh-users/zsh-autosuggestions is the last module in your ~/.zimrc.
ZSH_AUTOSUGGEST_MANUAL_REBIND=1

# Customize the style that the suggestions are shown with.
# See https://github.com/zsh-users/zsh-autosuggestions/blob/master/README.md#suggestion-highlight-style
#ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=242'

#
# zsh-syntax-highlighting
#

# Set what highlighters will be used.
# See https://github.com/zsh-users/zsh-syntax-highlighting/blob/master/docs/highlighters.md
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)

# Customize the main highlighter styles.
# See https://github.com/zsh-users/zsh-syntax-highlighting/blob/master/docs/highlighters/main.md#how-to-tweak-it
#typeset -A ZSH_HIGHLIGHT_STYLES
#ZSH_HIGHLIGHT_STYLES[comment]='fg=242'

# ------------------
# Initialize modules
# ------------------

ZIM_HOME=${ZDOTDIR:-${HOME}}/.zim
# Download zimfw plugin manager if missing.
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
	if (( ${+commands[curl]} )); then
		curl -fsSL --create-dirs -o ${ZIM_HOME}/zimfw.zsh \
			https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh
	else
		mkdir -p ${ZIM_HOME} && wget -nv -O ${ZIM_HOME}/zimfw.zsh \
			https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh
	fi
fi
# Install missing modules, and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE:-${ZDOTDIR:-${HOME}}/.zimrc} ]]; then
	source ${ZIM_HOME}/zimfw.zsh init -q
fi
# Initialize modules.
source ${ZIM_HOME}/init.zsh

# ------------------------------
# Custom post-init configuration
# ------------------------------

# GPG
GPG_TTY="$(tty)"
export GPG_TTY

# Path mangling for user executables (Python, etc.)
path=(${HOME}/.local/bin $path)

# Go
export GOPATH=${HOME}/go
path=(${GOPATH}/bin $path)

# Allow command line editing in an external editor in the "vicmd" keymap.
# Zim's "input" module already enables this in the default keymap ("viins").
bindkey -M vicmd "${key_info[Control]}x${key_info[Control]}e" edit-command-line

# Commands completion
(( $+commands[limactl] )) && . <(limactl completion zsh) && compdef _limactl limactl

# Aliases
alias Gid='git diff --cached'
alias GiD='git diff --cached --word-diff'
alias Gwd='git diff'
alias GwD='git diff --word-diff'
alias Grif=__git_rebase_fuzzy
__git_rebase_fuzzy() {
	local selected commit
	local -i count=25
	if (($# == 1)); then
		count=$1
	fi
	selected="$(git log -${count} --date-order --pretty=format:'%h %s%d' \
		| fzf -0 --no-multi --preview='git show --color=always {1}')"
	local ret=$?
	if [ -z ${selected} ]; then
		return $ret
	fi
	commit=$(awk '{print $1}' <<< ${selected})
	git rebase --interactive --autosquash "${commit}^"
}

# Shell theming
fzf_default_opts=(${FZF_DEFAULT_OPTS} '--color=16' '--color=fg+:7,hl:3,hl+:11,prompt:6,pointer:4,marker:5,info:2')
export FZF_DEFAULT_OPTS=${fzf_default_opts}
unset fzf_default_opts

# Difftastic
export DFT_BACKGROUND=light  # disable usage of bright ANSI colors

# Sets a fixed termtitle for the current terminal
termtitle() {
	local zhooks zhook
	zstyle -a ':zim:termtitle' hooks 'zhooks' || zhooks=(precmd)
	for zhook in ${zhooks}; do
		add-zsh-hook -d ${zhook} termtitle_update_${zhook}
	done
	local -a print_args=(-rn)
	(( $+_ghostty_fd )) && print_args+=(-u $_ghostty_fd)
	print $print_args $'\e]2;'${(q)@}$'\a'
}

# Prints the state of charge of both sides of the TOTEM keyboard.
totem_bat_soc() {
	local DEV_ID='E6:B9:0F:B2:F4:04'

	# D-Bus object paths:
	# GATT characteristics with the UUID '00002a19-0000-1000-8000-00805f9b34fb' (Battery level)
	local BAT_L=/service0010/char0011
	local BAT_R=/service0015/char0016

	read_soc() {
		local dev_path=$1
		local obj_path=/org/bluez/hci0/dev_"${DEV_ID//:/_}${dev_path}"
		# See: busctl introspect org.bluez $obj_path
		# Returns: <sig> <size> <val>
		local out
		out="$(2>/dev/null busctl call org.bluez "$obj_path" org.bluez.GattCharacteristic1 ReadValue 'a{sv}' 0)" \
			|| return $?
		printf '%s' "${out: -2}"
	}

	local -i exit_code=0
	local -i soc_l=0 soc_r=0
	soc_l="$(read_soc $BAT_L)" soc_r="$(read_soc $BAT_R)" || exit_code=$?
	unfunction read_soc

	if ((exit_code)); then
		>&2 echo disconnected
		return $exit_code
	fi
	printf 'L:%s%% R:%s%%\n' $soc_l $soc_r
}

_nix_devshell_completions() {
	(( ${+IN_NIX_SHELL} )) || return

	local -a new_paths

	local dir
	for dir in ${(s.:.)XDG_DATA_DIRS}; do
		local completion_dir="$dir/zsh/site-functions"
		if [[ -d "$completion_dir" ]]; then
			# zshexpn(1), Parameter Expansion Flags
			if (( ! ${fpath[(I)$completion_dir]} )); then
				new_paths+=("$completion_dir")
			fi
		fi
	done

	if (( ${#new_paths} )); then
		fpath=($new_paths $fpath)
		autoload -Uz compinit && compinit -D
	fi
}
add-zsh-hook precmd _nix_devshell_completions

# Source local environment
if [[ -s ${ZDOTDIR:-${HOME}}/.zshrc.local ]]; then
	. ${ZDOTDIR:-${HOME}}/.zshrc.local
fi
